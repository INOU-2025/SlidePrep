{
  "general": {
    "input_path": "",
    "output_path": "output", 
    "suffix_filter": "",
    "output_suffix": "",
    "log": true,
    "debug": false
  },
  "log": {
    "log_to_file": true,
    "log_to_console": false,
    "log_file_name": "slideprep.log",
    "log_level": "WARNING",
    "output_dir": "logs"
  },
  "binarization": {
    "threshold_method": "combined_differential"
  },
  "grid_detection": {
    "min_contour_area": 100,
    "threshold": 0.1,
    "angles": [2.0, -2.0],
    "enable_early_exit": true,
    "enable_template_cache": true,
    "enable_preprocessing_cache": true,
    "cache_max_size": 50,
    "general": {
      "template_length": 300,
      "thickness": 20,
      "border_thickness": 0
    },
    "thick_border": {
      "template_length": 100,
      "thickness": 7,
      "border_thickness": 35
    },
    "thin_border": {
      "template_length": 30,
      "thickness": 7,
      "border_thickness": 20
    }
  },
  "debug": {
    "output_dir": "debug_output",
    "save_composite": false
  }
}
