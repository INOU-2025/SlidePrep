{
  "general": {
    "input_path": "test_images",
    "output_path": "",
    "suffix_filter": "_binarized",
    "output_suffix": "_grid_detected",
    "log": true,
    "debug": true
  },
  "grid_detection": {
    "angle_deg": 2.0,
    "margin": 5,
    "percentile_thresh": 2,
    "horizontal_area_threshold": 2000,
    "vertical_area_threshold": 2000,
    "line_length": 40,
    "line_thickness": 21,
    "length_threshold_factor": 0.55
  },
  "log": {
    "log_to_file": false,
    "log_to_console": true,
    "log_file_name": "grid_detection_test.log",
    "log_level": "INFO",
    "output_dir": "logs"
  },
  "debug": {
    "output_dir": "debug_output/test_grid_detection",
    "save_composite": false
  }
}
