{
  "general": {
    "input_path": "",
    "suffix_filter": "",
    "output_path": "output",
    "output_suffix": "",
    "log": true,
    "debug": true
  },
  "log": {
    "log_to_file": true,
    "log_to_console": true,
    "log_file_name": "dev.log",
    "log_level": "DEBUG",
    "relative_path": "log"
  },
  "binarization": {
    "threshold_method": "combined_differential"
  },
  "grid_detection": {
    "threshold": 0.1,
    "angles": [2.0, -2.0],
    "enable_early_exit": true,
    "enable_template_cache": true,
    "enable_preprocessing_cache": true,
    "cache_max_size": 50,
    "general": {
      "template_length": 300,
      "thickness": 20,
      "border_thickness": 0,
      "min_contour_area": 100
    },
    "thick_border": {
      "template_length": 100,
      "thickness": 7,
      "border_thickness": 35,
      "min_contour_area": 100
    },
    "thin_border": {
      "template_length": 30,
      "thickness": 7,
      "border_thickness": 20,
      "min_contour_area": 100
    }
  },
  "grid_refinement": {
    "classifier": {
      "model_path": "models/rf_detection_classifier.joblib",
      "features": [
        "orientation_mismatch",
        "long_side_angle",
        "aspect_ratio",
        "corner_proximity",
        "area",
        "length"
      ],
      "threshold": 0.5
    }
  },
  "inpainting": {
    "model": "lama",
    "mask_path": "",
    "mask_suffix": "_mask"
  },
  "debug": {
    "relative_path": "debug",
    "saved_artifact_type": "both",
    "save_composite_img": true,
    "save_aggregated_data": true
  }
}
